# Earth Online 环境变量配置
# 复制此文件为 .env 并填入真实值

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/earthonline

# 安全配置（生产环境务必修改为随机值）
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS 配置
# 多个域名用逗号分隔，例如：http://localhost:3000,https://yourdomain.com
# 开发环境可设为：http://localhost:5173,http://localhost:5174,http://localhost:5175,http://127.0.0.1:5173
# 生产环境必须配置具体域名，严禁使用 *
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://127.0.0.1:5173

# Redis 配置
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
